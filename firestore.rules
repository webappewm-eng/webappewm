rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    match /categories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /subtopics/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /posts/{docId} {
      allow read: if resource.data.isPublished == true || isAdmin();
      allow write: if isAdmin();
    }

    match /feedback/{docId} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.postId is string
        && request.resource.data.message is string
        && request.resource.data.rating is int;
      allow update, delete: if false;
    }

    match /subscriptions/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /custom_pages/{docId} {
      allow read: if resource.data.isPublished == true || isAdmin();
      allow write: if isAdmin();
    }

    match /third_party_scripts/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /analytics_events/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /live_presence/{docId} {
      allow create, update: if true;
      allow read, delete: if isAdmin();
    }

    match /site_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
