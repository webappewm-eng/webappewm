rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdminEmail() {
      return isSignedIn()
        && request.auth.token.email is string
        && request.auth.token.email == "webappewm@gmail.com";
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true
        || isAdminEmail()
      );
    }

    function communityApprovalEnabled() {
      return exists(/databases/$(database)/documents/site_settings/global)
        && get(/databases/$(database)/documents/site_settings/global).data.communityApprovalEnabled == true;
    }

    match /categories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /subtopics/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /posts/{docId} {
      allow read: if resource.data.isPublished == true || isAdmin();
      allow write: if isAdmin();
    }

    match /feedback/{docId} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.postId is string
        && request.resource.data.message is string
        && request.resource.data.rating is int;
      allow update, delete: if false;
    }

    match /subscriptions/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /custom_pages/{docId} {
      allow read: if resource.data.isPublished == true || isAdmin();
      allow write: if isAdmin();
    }

    match /landing_topics/{docId} {
      allow read: if resource.data.isPublished == true || isAdmin();
      allow write: if isAdmin();
    }

    match /third_party_scripts/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /navigation_links/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /hero_media/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /community_categories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /community_questions/{docId} {
      allow read: if isAdmin() || !communityApprovalEnabled() || resource.data.status == "approved";
      allow create: if request.resource.data.question is string && request.resource.data.categoryId is string;
      allow update, delete: if isAdmin();
    }

    match /community_answers/{docId} {
      allow read: if isAdmin() || !communityApprovalEnabled() || resource.data.status == "approved";
      allow create: if request.resource.data.answer is string
        && request.resource.data.categoryId is string
        && request.resource.data.questionId is string;
      allow update, delete: if isAdmin();
    }

    match /social_links/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /visitor_events/{docId} {
      allow create, update: if true;
      allow read: if true;
      allow delete: if isAdmin();
    }

    match /notifications/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /analytics_events/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /live_presence/{docId} {
      allow create, update: if true;
      allow read, delete: if isAdmin();
    }

    match /webinars/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /webinar_registrations/{docId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.webinarId is string;
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /courses/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /course_types/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /course_ads/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /course_progress/{docId} {
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow delete: if false;
    }

    match /certificate_templates/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /certificates/{docId} {
      allow create: if (isSignedIn() && request.resource.data.userId == request.auth.uid) || isAdmin();
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow update, delete: if isAdmin();
    }


    match /course_feedback/{docId} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.courseId is string
        && request.resource.data.message is string
        && request.resource.data.rating is int;
      allow update, delete: if false;
    }

    match /site_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{docId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == docId);
      allow create: if isSignedIn() && request.auth.uid == docId;
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == docId);
      allow delete: if isAdmin();
    }
  }
}









